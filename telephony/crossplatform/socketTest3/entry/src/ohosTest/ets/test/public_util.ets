export enum SocketErrorCodes {
  ERR_CODE_PARAMETER_ERROR = 401,
  ERR_NET_BAD_FILE_DESCRIPTOR = 2301009,
  ERR_CODE_CERT_ERROR = -1,
  ERR_CODE_BIND_ERROR = 2303600,
  ERR_REQUEST_ADDRESS_ERROR = 2303199,
  ERR_EIO = 2303105,
}

let portCounter = 60000;

export function getNextPort(): number {
  return portCounter++;
}

export class PortManager {
  private static usedPorts = new Set<number>();
  private static basePort = 60000;
  private static currentPort = PortManager.basePort;

  static allocate(): number {
    let port = PortManager.currentPort;
    let attempts = 0;
    const maxAttempts = 2000;

    while (PortManager.usedPorts.has(port) && attempts < maxAttempts) {
      port++;
      attempts++;
      if (port > 65535) {
        port = PortManager.basePort;
      }
    }

    if (attempts >= maxAttempts) {
      throw new Error('No available ports after ' + maxAttempts + ' attempts');
    }

    PortManager.usedPorts.add(port);
    PortManager.currentPort = port + 1;

    if (PortManager.currentPort > 65535) {
      PortManager.currentPort = PortManager.basePort;
    }
    return port;
  }

  static release(port: number): void {
    PortManager.usedPorts.delete(port);
  }

  static reset(): void {
    PortManager.usedPorts.clear();
    PortManager.currentPort = PortManager.basePort;
  }

  static getCurrentPort(): number {
    return PortManager.currentPort;
  }
}

export function sleep(ms: number) {
  return new Promise<ESObject>(resolve => setTimeout(resolve, ms));
}

export const netAddress: socket.NetAddress = {
  address: '0.0.0.0',
  port: 8080
};

export enum PlatformType {
  OPENHARMONY = 'OpenHarmony',
  ANDROID = 'Android',
  IOS = 'iOS',
  UNKNOWN = 'Unknown'
}

export class PlatformDetector {
  private static cachedPlatform: PlatformType | null = null;

  static getPlatform(): PlatformType {
    if (PlatformDetector.cachedPlatform) {
      return PlatformDetector.cachedPlatform;
    }

    const osFullName = (deviceInfo.osFullName || '').toLowerCase().trim();
    const deviceType = (deviceInfo.deviceType || '').toLowerCase().trim();

    let platform: PlatformType;

    if (deviceType.includes('ohos') || osFullName.includes('openharmony')) {
      platform = PlatformType.OPENHARMONY;
    } else if (deviceType.includes('android') || osFullName.includes('android')) {
      platform = PlatformType.ANDROID;
    } else if (deviceType.includes('ios') || osFullName.includes('ios')) {
      platform = PlatformType.IOS;
    } else {
      console.warn(`Unknown platform: ${deviceInfo.osFullName}`);
      platform = PlatformType.UNKNOWN;
    }

    PlatformDetector.cachedPlatform = platform;
    return platform;
  }

  static isOpenHarmony(): boolean {
    return PlatformDetector.getPlatform() === PlatformType.OPENHARMONY;
  }

  static isAndroid(): boolean {
    return PlatformDetector.getPlatform() === PlatformType.ANDROID;
  }

  static isIOS(): boolean {
    return PlatformDetector.getPlatform() === PlatformType.IOS;
  }

  static getPlatformSpecificErrorCode(baseCode: number): number {
    const platform = PlatformDetector.getPlatform();
    if (platform === PlatformType.IOS && baseCode === 2301009) {
      return 2301005;
    }
    return baseCode;
  }
}